    "def create_sample_timeseries_plot(site_type,cluster_ts_df,timeslice_df,color_mapping_dict,save_to):\n",
    "\n",
    "    df=cluster_ts_df\n",
    "    # Define the solar sites and select the first site for demonstration\n",
    "    sites = list(timeslice_df.keys())\n",
    "    mapped_CF = timeslice_df[sites[0]]['CF_mean'].to_dict()\n",
    "\n",
    "    # Apply the mapping directly to create the 'timeslice_CF' column\n",
    "    cluster_ts_df['timeslice_CF'] = cluster_ts_df.apply(lambda row: mapped_CF[timeslice_name_mapping[row['season_daytime']]], axis=1)\n",
    "\n",
    "    # Create the scatter plot\n",
    "    fig = go.Figure()\n",
    "\n",
    "    site=sites[0]\n",
    "    # Add Squamish-Lillooet_1 vs timeslice_CF with different colors based on 'season_daytime'\n",
    "    for season, color in color_mapping_dict.items():\n",
    "        df_season = df[df['season_daytime'] == season]\n",
    "        fig.add_trace(go.Scatter(\n",
    "            x=df_season.index,  # Use datetime index for the x-axis\n",
    "            y=df_season[site],\n",
    "            mode='markers',\n",
    "            text=df_season['season_daytime'],  # Use 'season_daytime' for text labels\n",
    "            marker=dict(\n",
    "                color=color,  # Assign color based on 'season_daytime'\n",
    "                opacity=0.7,\n",
    "                size=8,  # Adjust marker size as needed\n",
    "            ),\n",
    "            name=f'{season}'\n",
    "        ))\n",
    "\n",
    "    # Add timeslice_CF with marker mode\n",
    "    fig.add_trace(go.Scatter(\n",
    "        x=df.index,  # Use datetime index for the x-axis\n",
    "        y=df['timeslice_CF'],\n",
    "        mode='markers',  # Set mode to 'markers' for timeslice_CF\n",
    "        marker=dict(\n",
    "            color='maroon',  # Set marker color\n",
    "            opacity=0.6,\n",
    "            size=5,  # Adjust marker size as needed\n",
    "            symbol='x'  # Use 'x' symbol for markers\n",
    "        ),\n",
    "        name='BCNexus_timeslice'\n",
    "    ))\n",
    "\n",
    "    # Update layout\n",
    "    fig.update_layout(\n",
    "        title=f'{site_type}, Site: {site}',\n",
    "        xaxis_title='Datetime Index',\n",
    "        yaxis_title='Value',\n",
    "        showlegend=True,\n",
    "        xaxis=dict(rangeslider=dict(visible=True)),  # Add rangeslider for interactive zoom\n",
    "    )\n",
    "\n",
    "    # Show the plot\n",
    "    fig.write_html(f'vis/{site_type}- {site}.html')\n",
    "\n",
    "    return print(f\"A sample interactive plot created for {site_type}-{site}.html and saved to 'vis'\")"
   ]
