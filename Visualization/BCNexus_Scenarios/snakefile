rule visualization:
    input:
        capacity="Scripts/Capacity_VIS.py",
        emission="Scripts/Emission_VIS.py",
        energy="Scripts/Energy_VIS.py",
        landuse="Scripts/Landuse_VIS.py"

    shell:
        '''
        python {input.capacity}
        python {input.emission}
        python {input.energy}
        python {input.landuse}
        '''

# Rule for generating the DAG
rule make_graphs:
    message:
        'Graphs created successfully'
    output:
        'workflow_graphs/BCNexus_scenario_visualization_workflow_dag.svg',
        'workflow_graphs/BCNexus_scenario_visualization_workflow_filegraph.svg'
    shell:
        '''      
        # snakemake --dag Results | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o {output[0]}
        snakemake --forceall --dag | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o {output[0]}
        snakemake --filegraph | dot -Tsvg -o {output[1]}
        '''

# Copy all the plots to a single folder
rule collect_plots:
    input:
        "scenario_files"
    output:
        directory("scenario_all_PLOTS")
    run:
        shell("mkdir -p {output}")
        shell("find {input} -name '*.png' -exec cp {{}} {output} \;")
