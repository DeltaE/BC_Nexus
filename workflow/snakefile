# Define the rule all and the input is the file to generate which requires all associated rules to play.
### >>> Future Scope: Checks needed for required DIRECTORIES structure. If not available then MAKE DIRECTORIES
rule Results:
    input:
        'LP_file/BCNexus.lp'
    # output:
    #     'Result file generation Complete'
    # shell:
    #     'touch {output}'


# Rule for generating the DAG
rule make_dag:
    message:
        'DAG created successfully and saved as docs/dag.pdf'
    # input:
    #     'Result file generation Complete'
    shell:
        'snakemake --dag Results | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o docs/BCNexus_workflow_dag.svg'


# Generating the MODEL SHELL (i.e. SETS) with clewsy tool
configfile: 'config_files/20221207_BC_CLEWS_Elias.yaml'
rule Model_Shell:
    message:
        'Collecting the data files...'
    input:
        Input_files = ancient('user_inputs'),
        CLEW_Config_file = 'config_files/20221207_BC_CLEWS_Elias.yaml'
    output:
        directory(config['otooleOutputDirectory']),
        'Model_shell_complete'
    shell:
        '''
        clewsy build {input.CLEW_Config_file}
        [ -d {output[0]} ] && echo "BC NEXUS - SETS files Created Successfully." || echo "Model Shell Creation failed !!!"
        touch {output[1]}
        '''


# Collect the MODEL SHELL from clewsy and the other user input PARAMETERS' CSV files from different folders and store them in a single directory 'data'
rule Scenario_Data_Files:
    output:
        directory('data')
    shell:
        "python ./Scripts/organize_files.py"


# Rule for Converting CSV files to datafile "data.txt"
## INPUT is the "data" folder with all CSVs and OUTPUT is the "data.txt" file + Otoole enviroment file
### >>> Future scope: to verify a prescribed list of input CSV files inside "data" folder

rule Input_Data_Interfacing_otoole:
    message:
        'Creating data file...'
    input:
        datapackage='data',
        flag='Model_shell_complete'
        #rm \csv_files=expand('data/{osemosys_file}', osemosys_file=osemosys_files),
    output:
        data_file='data.txt'
    params:
        config_file='config_files/otoole_config.yaml'
    log:
        log='logs/otoole_convert.log'
    conda:
        'envs/otoole.yml'
    shell:
        '''
        if [ -f data/.snakemake_timestamp ]; then
            rm data/.snakemake_timestamp
        fi
        
        otoole convert csv datafile {input.datapackage} {output} {params.config_file} 2> {log}
        '''

# Preprocessing the data after Otoole Creates the "data.txt" file
# INPUT is the output datafile (.txt) from Otoole Rule + Model File + preprocessing python script , OUTPUT is another datafile in same format.
### >>> Future scope: xxx
rule Preprocess_data:
    input:
        data_in='data.txt',
        model='model/model_BCNexus.txt',
        script='Scripts/preprocess_data.py'
    output:
        data_out='processed_data.txt',
        processed_model='processed_model_BCNexus.txt'
    shell:
        'python {input.script} {input.data_in} {output.data_out} {input.model} {output.processed_model}'


# Creating directory if it doesn't exist. This directory is a REQUIREMENT for GLPK solver's output TABLE (tout) writing
if not os.path.isdir('res/csv'):
    os.makedirs('res/csv')

# Rule for MODEL RUN.
# INPUT is the result of pre-processing data rule and OUTPUT is the ./res/csv folder with result CSV files.
### >>> Future scopes: 
    # to verify a prescribed list of output CSV files inside "res/csv" folder
    # to include CBC/Gurobi solvers
    # introducing a CONFIG file where user choose the solver
# !!!!!! Issues:  (Installation of CBC solver needs to be resolved)
rule RUN_MODEL:
    input:
        data='processed_data.txt',
        model='model/model_BCNexus.txt',
    output:
        LP_file='LP_file/BCNexus.lp',
        # directory('.res/csv')
    shell:
        'glpsol -m {input.model} -d {input.data} --wlp {output.LP_file}'

# Execution status messages
onsuccess:
    print('Workflow finished successfully!')

onerror:
    print('An error occurred')

# Cleaning residual data
### >>> Future scopes: 
    # use wildcards for cleaning purposes
# !!!!!! Issues: It is a standalone rule.

rule clean:
    message:
        'Resetting to defaults and cleaning existing data...'
    shell:
        '''
        if [ -f data.txt ]; then
            rm data.txt
        fi

        if [ -f processed_data.txt ]; then
            rm processed_data.txt
        fi

        if [ -f processed_model_BCNexus.txt ]; then
            rm processed_model_BCNexus.txt
        fi

        if [ -d logs ]; then
            rm -rf logs/*
        fi

        if [ -d docs ]; then
            rm -rf docs/*
        fi

        # if [ -d LP_file ]; then
        #     rm -rf LP_file/*
        # fi

        if [ -d res/csv ]; then
            rm -rf res/csv/*
        fi
        '''

