# BC Nexus Input file preparation workflow

import os
from snakemake.utils import min_version
min_version("7.0")
from pathlib import Path

# Define the rule all and the input is the file to generate which requires all associated rules to play.
### >>> Future Scope: Checks needed for required DIRECTORIES structure. If not available then MAKE DIRECTORIES

rule Results:
    input:
        check_flag_static_plots='check_flags/static_Plots_generated.check',
        check_flag_interactive_plots='check_flags/interactive_Plots_generated.check',
        check_flag_results_files='check_flags/otoole_ResultsFile_genrated.check',
        RES_diagram='RES/BCNexus_RES.png'

# Rule for generating the DAG
rule make_graphs:
    message:
        'Graphs created successfully and saved as "docs/dag.pdf"'
    output:
        DAG='docs/BCNexus_workflow_dag.svg',
        RULEGRAPH='docs/BCNexus_workflow_Rulegraph.svg',
        FILEGRAPH='docs/BCNexus_workflow_filegraph.svg',
    shell:
        '''
        rm -f docs/*.svg
        snakemake --forceall --dag | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o {output.DAG}
        snakemake --rulegraph | dot -Tsvg -o {output.RULEGRAPH}
        snakemake --filegraph | dot -Tsvg -o {output.FILEGRAPH}
        '''

# Generating the MODEL SHELL (i.e. SETS) with clewsy tool
configfile: 'config_files/20230302_BCNexus_CLEWsy.yaml'

rule Model_Shell:
    message:
        'check_flags/Collecting the data files...'
    input:
        Input_files = 'user_inputs',
        CLEWsy_Config_file = 'config_files/20230302_BCNexus_CLEWsy.yaml'
    output:
        CLEWsy_outputs=directory((config['otooleOutputDirectory']).lstrip('./')),
        check_flag_1='check_flags/Model_shell_complete.check'
    shell:
        '''
        clewsy build {input.CLEWsy_Config_file}
        [ -d {output.CLEWsy_outputs} ] && echo "BC NEXUS - SETS files Created Successfully." || echo "Model Shell Creation failed !!!"
        touch {output.check_flag_1}
        '''

# Collect the MODEL SHELL from clewsy and the other user input PARAMETERS' CSV files from different folders and store them in a single directory 'data'
rule Scenario_Data_Files:
    input:
        check_flag_1='check_flags/Model_shell_complete.check',
        # 'check_flags/Data_Updated.check',
        organize_files='scripts/organize_files.py'
    output:
       CLEWs_model_input_data_direc=directory('data'),
        # 'Scenario Data folder Created.check'
    shell:
        '''
        python {input.organize_files}
        '''

# Rule for Converting CSV files to datafile "data.txt"
## INPUT is the "data" folder with all CSVs and OUTPUT is the "data.txt" file + Otoole enviroment file
### >>> Future scope: to verify a prescribed list of input CSV files inside "data" folder

rule Input_Data_Interfacing_otoole:
    message:
        'Creating data file...'
    input:
        CLEWs_model_input_data_direc='data',
    output:
        CLEWs_model_input_datafile='data.txt',
        check_flag_1='check_flags/otoole_datafile_prepared.check'
    params:
        'config_files/otoole_config.yaml'
    log:
        log='logs/otoole_convert.log'
    # conda:
    #     'envs/otoole.yml'
    # if [ -f data/.snakemake_timestamp ]; then
    #     rm data/.snakemake_timestamp
    # fi
    shell:
        '''
        otoole convert csv datafile {input.CLEWs_model_input_data_direc} {output.CLEWs_model_input_datafile} {params} 2> {log}
        touch {output.check_flag_1}
        '''

if not os.path.isdir('RES'):
    os.makedirs('RES')

rule make_RES:
    message:
        'Creating Reference Energy System (RES)...'
    input:
        check_flag_1='check_flags/otoole_datafile_prepared.check',
        CLEWs_model_input_datafile='data.txt'
    output:
        RES_diagram='RES/BCNexus_RES.png'
    params:
        otoole_config='config_files/otoole_config.yaml'
    # conda:
    #     'envs/otoole.yml'
    shell:
        '''
        otoole viz res datafile {input.CLEWs_model_input_datafile} {output.RES_diagram} {params.otoole_config}
        '''

# Preprocessing the data after Otoole Creates the "data.txt" file
# INPUT is the output datafile (.txt) from Otoole Rule + Model File + preprocessing python script , OUTPUT is another datafile in same format.
### >>> Future scope: xxx
rule Preprocess_data:
    input:
        CLEWs_model_input_datafile='data.txt',
        CLEWs_model='model/model_BCNexus.txt',
        otoole_preprocessing_script='scripts/preprocess_data.py'
    output:
        CLEWs_model_input_datafile_toole_processed='processed_data.txt',
        CLEWs_model_otoole_processed='processed_model_BCNexus.txt'
    shell:
        'python {input.otoole_preprocessing_script} {input.CLEWs_model_input_datafile} {output.CLEWs_model_input_datafile_toole_processed} {input.CLEWs_model} {output.CLEWs_model_otoole_processed}'

# Rule for MODEL RUN.
# INPUT is the result of pre-processing data rule and OUTPUT is the ./res/csv folder with result CSV files.
### >>> Future scopes: xxx
if not os.path.isdir('LP_file'):
    os.makedirs('LP_file')

rule RUN_MODEL:
    input:
        data='processed_data.txt',
        model='processed_model_BCNexus.txt'
    output:
        LP_file='LP_file/BCNexus.lp',
        solution_file='docs/CBC_solution.sol'
    threads: 8
    shell:
        '''
        if test -d "{output.LP_file}" && ! test -d "{output.solution_file}"; then
            cbc "{output.LP_file}" solve -solu "{output.solution_file}"
        else
            glpsol -m "{input.model}" -d "{input.data}" --wlp "{output.LP_file}" --check
            cbc "{output.LP_file}" solve -solu "{output.solution_file}"
        fi
        '''

if not os.path.isdir('results'):
    os.makedirs('results')
    
rule Output_Data_Interfacing_otoole:
    message:
        'Generating result files...'
    input:
        solution_file='docs/CBC_solution.sol'
    output:
        results_direc=directory("results"),
        check_flag_1='check_flags/otoole_ResultsFile_genrated.check'
    params:
        otoole_config='config_files/otoole_config.yaml'
    # conda:
    #     'envs/otoole.yml'
    shell:
        '''
        otoole results cbc csv {input.solution_file} results csv data {params.otoole_config}
        touch {output.check_flag_1}
        '''

rule visualization_static:
    input:
        check_flag_1='check_flags/otoole_ResultsFile_genrated.check',
        capacity_plots_static='scripts/Capacity_VIS.py',
        energy_plots_static='scripts/Energy_VIS.py',
        emission_plots_static='scripts/Emission_VIS.py',
        landuse_plots_static='scripts/Landuse_VIS.py',
        dashboard_plots_static='scripts/Dashboard.py',
    output:
        check_flag_1='check_flags/static_Plots_generated.check'
    shell:
        '''
        python {input.capacity_plots_static}
        python {input.energy_plots_static}
        python {input.emission_plots_static}
        python {input.landuse_plots_static}
        python {input.dashboard_plots_static}
        touch {output.check_flag_1}
        '''

rule visualization_interactive:
    input:
        check_flag_1='check_flags/otoole_ResultsFile_genrated.check',
        capacity_plots_interactive='scripts/Capacity_VIS_v3.py',
        energy_plots_interactive='scripts/Energy_VIS_v2.py',
