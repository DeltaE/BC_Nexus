scenario_files=os.path.join('workflow/BCNexus_Scenarios/scenario_files',config['SCENARIO_name'])
if not os.path.isdir(scenario_files):
    os.makedirs(scenario_files)

rule scenario_Results:
    input:
        check_flag_otoole_results='workflow/check_flags/otoole_ResultsFile_genrated.check',
        CLEWs_model_input_datafile='workflow/data.txt',
        CLEWs_model='model/model_BCNexus.txt',
        results_direc=directory('results')
    output:
       check_flag_scenario_file_dump='workflow/check_flags/check_flag_scenario_file_dump.check',
       scenario_files=directory(os.path.join('workflow/BCNexus_Scenarios/scenario_files', config['SCENARIO_name']))
    shell:
        '''
        cp -r {input.results_direc} {output.scenario_files} 
        cp {input.CLEWs_model_input_datafile} {output.scenario_files}
        touch {output.check_flag_scenario_file_dump}
        '''

rule deploy_dashboard:
    input:
        check_flag_scenario_file_dump='workflow/check_flags/check_flag_scenario_file_dump.check',
    output:
        check_flag_dash='workflow/check_flags/dashboard_deployed.check',
    shell:
        '''
        bash dashboard.sh deploy
        echo "Press 'CTRL+C' to Exit from Command Line"
        '''

# Cleaning residual data

rule clean:
    message:
        'Resetting to defaults and cleaning existing data...'
    shell:
        '''
        read -p "Do you want to clean the existing results? (y/n): " clean_choice
        if [[ "$clean_choice" == "y" ]]; then
                        
            # Deletes Spefic Files
            rm -f data.xlsx data.txt processed_data.txt processed_model_BCNexus.txt Modelist.txt docs/Run_Summary.txt 

            # Deletes all files/specific extension under directories
            rm -rf workflow/logs/* workflow/docs/* workflow/LP_file/*.svg results/* user_inputs/Sets/clewsy_output/*.csv workflow/check_flags/*
            
            # Remove entire folder
            # rm -rf workflow/data
            
            echo "Existing results cleaned."
        else
            echo "No cleaning operation performed."
            exit 0
        fi
        '''


