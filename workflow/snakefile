# BC Nexus Input file preparation workflow

import os
from snakemake.utils import min_version
min_version("7.0")
from pathlib import Path



# Define the rule all and the input is the file to generate which requires all associated rules to play.
### >>> Future Scope: Checks needed for required DIRECTORIES structure. If not available then MAKE DIRECTORIES
rule Results:
    input:
        'check_flags/Plots_generated.check',
        'check_flags/otoole_ResultsFile_genrated.check',
        'docs/BCNexus_RES.png'

# Rule for generating the DAG
rule make_graphs:
    message:
        'Graphs created successfully and saved as "docs/dag.pdf"'
    output:
        'docs/BCNexus_workflow_dag.svg',
        'docs/BCNexus_workflow_Rulegraph.svg',
        'docs/BCNexus_workflow_filegraph.svg',
    shell:
        '''
        rm -f docs/*.svg
        snakemake --forceall --dag | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o {output[0]}
        snakemake --rulegraph | dot -Tsvg -o {output[1]}
        snakemake --filegraph | dot -Tsvg -o {output[2]}
        '''

# Generating the MODEL SHELL (i.e. SETS) with clewsy tool
configfile: 'config_files/20230302_BCNexus_CLEWsy.yaml'

rule Model_Shell:
    message:
        'check_flags/Collecting the data files...'
    input:
        Input_files = 'user_inputs',
        CLEW_Config_file = 'config_files/20230302_BCNexus_CLEWsy.yaml'
    output:
        directory((config['otooleOutputDirectory']).lstrip('./')),
        'check_flags/Model_shell_complete.check'
    shell:
        '''
        clewsy build {input.CLEW_Config_file}
        [ -d {output[0]} ] && echo "BC NEXUS - SETS files Created Successfully." || echo "Model Shell Creation failed !!!"
        touch {output[1]}
        '''

# Collect the MODEL SHELL from clewsy and the other user input PARAMETERS' CSV files from different folders and store them in a single directory 'data'
rule Scenario_Data_Files:
    input:
        'check_flags/Model_shell_complete.check',
        'check_flags/Data_Updated.check',
        organize_files='Scripts/organize_files.py'
    output:
        directory('data'),
        # 'Scenario Data folder Created.check'
    shell:
        '''
        python {input.organize_files}
        '''

# Rule for Converting CSV files to datafile "data.txt"
## INPUT is the "data" folder with all CSVs and OUTPUT is the "data.txt" file + Otoole enviroment file
### >>> Future scope: to verify a prescribed list of input CSV files inside "data" folder

rule Input_Data_Interfacing_otoole:
    message:
        'Creating data file...'
    input:
        datapackage='data',
    output:
        'data.txt',
        'check_flags/otoole_datafile_prepared.check'
    params:
        'config_files/otoole_config.yaml'
    log:
        log='logs/otoole_convert.log'
    conda:
        'envs/otoole.yml'
    shell:
        '''
        if [ -f data/.snakemake_timestamp ]; then
            rm data/.snakemake_timestamp
        fi

        otoole convert csv datafile {input.datapackage} {output[0]} {params} 2> {log}
        touch {output[1]}
        '''
rule make_RES:
    message:
        'Creating Reference Energy System (RES)...'
    input:
        'check_flags/otoole_datafile_prepared.check',
        'data.txt'
    output:
        'docs/BCNexus_RES.png'
    params:
        'config_files/otoole_config.yaml'
    conda:
        'envs/otoole.yml'
    shell:
        '''
        otoole viz res datafile {input[1]} {output} {params}
        '''

# Preprocessing the data after Otoole Creates the "data.txt" file
# INPUT is the output datafile (.txt) from Otoole Rule + Model File + preprocessing python script , OUTPUT is another datafile in same format.
### >>> Future scope: xxx
rule Preprocess_data:
    input:
        data_in='data.txt',
        model='model/model_BCNexus.txt',
        script='Scripts/preprocess_data.py'
    output:
        data_out='processed_data.txt',
        processed_model='processed_model_BCNexus.txt'
    shell:
        'python {input.script} {input.data_in} {output.data_out} {input.model} {output.processed_model}'

# Rule for MODEL RUN.
# INPUT is the result of pre-processing data rule and OUTPUT is the ./res/csv folder with result CSV files.
### >>> Future scopes: xxx
if not os.path.isdir('LP_file'):
    os.makedirs('LP_file')

rule RUN_MODEL:
    input:
        data='processed_data.txt',
        model='processed_model_BCNexus.txt'
    output:
        'LP_file/BCNexus.lp',
        'docs/CBC_solution.sol'
    threads: 8
    shell:
        '''
        if test -d "{output[0]}" && ! test -d "{output[1]}"; then
            cbc "{output[0]}" solve -solu "{output[1]}"
        else
            glpsol -m "{input.model}" -d "{input.data}" --wlp "{output[0]}" --check
            cbc "{output[0]}" solve -solu "{output[1]}"
        fi
        '''

if not os.path.isdir('results'):
    os.makedirs('results')
    
rule Output_Data_Interfacing_otoole:
    message:
        'Generating result files...'
    input:
        'docs/CBC_solution.sol'
    output:
        directory("results"),
        'check_flags/otoole_ResultsFile_genrated.check'
    params:
        'config_files/otoole_config.yaml'
    conda:
        'envs/otoole.yml'
    shell:
        '''
        otoole results cbc csv {input} results {params}
        touch {output[1]}
        '''

rule Visualization:
    input:
        'check_flags/otoole_ResultsFile_genrated.check',
        'Scripts/Capacity_VIS.py',
        'Scripts/Energy_VIS.py',
        'Scripts/Emission_VIS.py',
        'Scripts/Landuse_VIS.py',
        'Scripts/Dashboard.py',
    output:
        'check_flags/Plots_generated.check'
    shell:
        '''
        python {input[1]}
        python {input[2]}
        python {input[3]}
        python {input[4]}
        python {input[5]}
        touch {output}
        '''

# Execution status messages
onsuccess:
    print('Workflow finished successfully!')

onerror:
    print('An error occurred')

# Cleaning residual data
### >>> Future scopes: 
    # use wildcards for cleaning purposes
# !!!!!! Issues: It is a standalone rule.

rule clean:
    message:
        'Resetting to defaults and cleaning existing data...'
    shell:
        '''
        read -p "Do you want to clean the existing results? (y/n): " clean_choice
        if [[ "$clean_choice" == "y" ]]; then
                        
            # Deletes Spefic Files
            rm -f data.xlsx data.txt processed_data.txt processed_model_BCNexus.txt Modelist.txt docs/Run_Summary.txt 

            # Deletes all files/specific extension under directories
            rm -rf logs/* docs/* LP_file/*.svg results/* user_inputs/Sets/clewsy_output/*.csv check_flags/*.check
            
            # Remove entire folder
            rm -rf data
            
            echo "Existing results cleaned."
        else
            echo "No cleaning operation performed."
            exit 0
        fi
        '''


