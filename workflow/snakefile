rule clean:
    message:
        'Resetting to defaults and cleaning existing data...'
    shell:
        '''
        if [ -f data.txt ]; then
            rm data.txt
        fi

        if [ -f processed_data.txt ]; then
            rm processed_data.txt
        fi

        if [ -f processed_model_BCNexus.txt ]; then
            rm processed_model_BCNexus.txt
        fi

        if [ -d logs ]; then
            rm -rf logs/*
        fi

        if [ -d docs ]; then
            rm -rf docs/*
        fi

        # if [ -d LP_file ]; then
        #     rm -rf LP_file/*
        # fi

        if [ -d res/csv ]; then
            rm -rf res/csv/*
        fi
        '''

