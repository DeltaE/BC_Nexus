# BC Nexus Input file preparation workflow

import os
from snakemake.utils import min_version
min_version("8.5")
from pathlib import Path
import scripts.utilities as utils

configfile: 'config/BCNexus_CLEWsy.yaml'

# Define the rule all and the input is the file to generate which requires all associated rules to play.
### >>> Future Scope: Checks needed for required DIRECTORIES structure. If not available then MAKE DIRECTORIES

# Rule for generating the DAG

rule all:
    input:
        # check_flag_static_plots='workflow/check_flags/static_Plots_generated.check',
        # check_flag_interactive_plots='workflow/check_flags/interactive_Plots_generated.check',
        check_flag_results_files='workflow/check_flags/otoole_ResultsFile_genrated.check',
        check_flag_dash='workflow/check_flags/dashboard_deployed.check',
        RES_diagram='RES/BCNexus_RES.png',
        check_flag_scenario_file_dump='workflow/check_flags/check_flag_scenario_file_dump.check',
   
rule make_graphs:
    message:
        "Graphs created successfully and saved to 'docs'"
    output:
        DAG='workflow/docs/BCNexus_workflow_dag.svg',
        RULEGRAPH='workflow/docs/BCNexus_workflow_Rulegraph.svg',
        FILEGRAPH='workflow/docs/BCNexus_workflow_filegraph.svg'
    shell:
        '''
        snakemake --forceall --dag | dot -Tsvg -Gsize="8.3,11.7" -Gorientation="portrait" -o {output.DAG}
        snakemake --rulegraph | dot -Tsvg -o {output.RULEGRAPH} 
        snakemake --filegraph | dot -Tsvg -o {output.FILEGRAPH}
        '''

# Generating the MODEL SHELL (i.e. SETS) with clewsy tool
rule Model_Shell:
    message:
        'Collecting the data files...'
    input:
        Input_files = 'user_inputs',
        CLEWsy_Config_file = 'config/BCNexus_CLEWsy.yaml'
    output:
        CLEWsy_outputs=directory((config['otooleOutputDirectory']).lstrip('./')),
        check_flag_model_shell='workflow/check_flags/Model_shell_complete.check'
    shell:
        '''
        clewsy build {input.CLEWsy_Config_file}
        [ -d {output.CLEWsy_outputs} ] && echo "BC NEXUS - SETS files Created Successfully." || echo "Model Shell Creation failed !!!"
        touch {output.check_flag_model_shell}
        '''

# Rule for Converting CSV files to datafile "data.txt"
## INPUT is the "data" folder with all CSVs and OUTPUT is the "data.txt" file + Otoole enviroment file
### >>> Future scope: to verify a prescribed list of input CSV files inside "data" folder

rule Input_Data_Interfacing_otoole:
    message:
        'Creating data file...'
    input:
        check_flag_model_shell='workflow/check_flags/Model_shell_complete.check',
        CLEWs_model_input_data_direc='data',
    output:
        CLEWs_model_input_datafile='workflow/data.txt',
        check_flag_input_datafile='workflow/check_flags/otoole_datafile_prepared.check'
    params:
        'config/otoole_config.yaml'
    log:
        log='workflow/logs/otoole_convert.log'
    # conda:
    #     'envs/otoole.yml'
    # if [ -f data/.snakemake_timestamp ]; then
    #     rm data/.snakemake_timestamp
    # fi
    shell:
        '''
        otoole convert csv datafile {input.CLEWs_model_input_data_direc} {output.CLEWs_model_input_datafile} {params} 2> {log}
        touch {output.check_flag_input_datafile}
        '''

if not os.path.isdir('RES'):
    os.makedirs('RES')

rule make_RES:
    message:
        'Creating Reference Energy System (RES)...'
    input:
        check_flag_input_datafile='workflow/check_flags/otoole_datafile_prepared.check',
        CLEWs_model_input_datafile='workflow/data.txt'
    output:
        RES_diagram='RES/BCNexus_RES.png'
    params:
        otoole_config='config/otoole_config.yaml'
    # conda:
    #     'envs/otoole.yml'
    shell:
        '''
        otoole viz res datafile {input.CLEWs_model_input_datafile} {output.RES_diagram} {params.otoole_config}
        '''

# Preprocessing the data after Otoole Creates the "data.txt" file
# INPUT is the output datafile (.txt) from Otoole Rule + Model File + preprocessing python script , OUTPUT is another datafile in same format.
### >>> Future scope: xxx
rule Preprocess_data:
    input:
        check_flag_input_datafile='workflow/check_flags/otoole_datafile_prepared.check',
        CLEWs_model_input_datafile='workflow/data.txt',
        CLEWs_model='model/model_BCNexus.txt',
        otoole_preprocessing_script='workflow/scripts/preprocess_data.py'
    output:
        CLEWs_model_input_datafile_toole_processed='workflow/processed_data.txt',
        CLEWs_model_otoole_processed='workflow/processed_model_BCNexus.txt'
    shell:
        'python {input.otoole_preprocessing_script} {input.CLEWs_model_input_datafile} {output.CLEWs_model_input_datafile_toole_processed} {input.CLEWs_model} {output.CLEWs_model_otoole_processed}'

# Rule for MODEL RUN.
# INPUT is the result of pre-processing data rule and OUTPUT is the ./res/csv folder with result CSV files.
### >>> Future scopes: xxx
if not os.path.isdir('LP_file'):
    os.makedirs('LP_file')

rule RUN_MODEL:
    input:
        CLEWs_model_input_datafile_toole_processed='workflow/processed_data.txt',
        CLEWs_model_otoole_processed='workflow/processed_model_BCNexus.txt'
    output:
        LP_file='workflow/LP_file/BCNexus.lp',
        solution_file='workflow/docs/CBC_solution.sol',
        check_flag_model_run='workflow/check_flags/check_flag_model_run.check',
    threads: 8
    shell:
        '''
        if test -d "{output.LP_file}" && ! test -d "{output.solution_file}"; then
            cbc "{output.LP_file}" solve -solu "{output.solution_file}"
        else
            glpsol -m "{input.CLEWs_model_otoole_processed}" -d "{input.CLEWs_model_input_datafile_toole_processed}" --wlp "{output.LP_file}" --check
            cbc "{output.LP_file}" solve -solu "{output.solution_file}"
        fi
        touch {output.check_flag_model_run}
        '''

if not os.path.isdir('results'):
    os.makedirs('results')
    
rule Output_Data_Interfacing_otoole:
    message:
        'Generating result files...'
    input:
        check_flag_model_run='workflow/check_flags/check_flag_model_run.check',
        solution_file='workflow/docs/CBC_solution.sol'
    output:
        results_direc=directory('results'),
        check_flag_otoole_results='workflow/check_flags/otoole_ResultsFile_genrated.check',
    params:
        otoole_config='config/otoole_config.yaml'
    # conda:
    #     'envs/otoole.yml'
    shell:
        '''
        otoole results cbc csv {input.solution_file} results csv data {params.otoole_config}
        touch {output.check_flag_otoole_results}
        '''

